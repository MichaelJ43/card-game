{
  "name": "card-game-lambda",
  "private": true,
  "version": "0.1.0",
  "description": "AWS Lambda handlers for card-game multiplayer signaling.",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bundle": "node ./scripts/bundle.mjs",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.651.0",
    "@aws-sdk/client-auto-scaling": "^3.1039.0",
    "@aws-sdk/client-dynamodb": "^3.651.0",
    "@aws-sdk/client-ec2": "^3.651.0",
    "@aws-sdk/client-route-53": "^3.651.0",
    "@aws-sdk/lib-dynamodb": "^3.651.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.140",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.0",
    "archiver": "^7.0.1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  }
}
